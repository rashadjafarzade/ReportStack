# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Anthropic API Key (for Claude AI)
ANTHROPIC_API_KEY=sk-ant-...

# Claude model to use
CLAUDE_MODEL=claude-sonnet-4-20250514

# Backend API URL (the automation-reports backend)
AR_BACKEND_URL=http://localhost:8000/api/v1

# Frontend URL (for sharing links)
AR_FRONTEND_URL=http://localhost:3000

# Comma-separated Telegram user IDs allowed to use the bot (empty = allow all)
ALLOWED_USER_IDS=

# Max conversation history to keep per user
MAX_HISTORY=20
