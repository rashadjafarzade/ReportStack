DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automation_reports

# Storage backend: "minio" (default, dev) or "local" (prod on twd00030)
STORAGE_BACKEND=minio
ATTACHMENT_STORAGE_PATH=/data/attachments

# AI analysis
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral:7b
AI_ANALYSIS_ENABLED=false

# Compose project name — Jenkinsfile depends on reports-app_default network
COMPOSE_PROJECT_NAME=reports-app
