{
  "name": "reportstack-e2e",
  "version": "1.0.0",
  "private": true,
  "description": "End-to-end Playwright tests for the ReportStack web UI + backend",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
